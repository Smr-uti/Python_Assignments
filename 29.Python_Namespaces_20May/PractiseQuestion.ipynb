   "source": [
    "Q1.  Write a program that demonstrates all four LEGB levels\n",
    "     in one nested structure:"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "acc0db20",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "global\n"
     ]
    }
   ],
   "source": [
    "x = 'global'\n",
    "\n",
    "def outer():\n",
    "    x='enclosing'\n",
    "\n",
    "    def inner():\n",
    "        x = 'local'\n",
    "        print(x)\n",
    "\n",
    "        inner()\n",
    "outer()\n",
    "print(x)\n",
    "\n",
    "\n"
   ]
  }
 ],
